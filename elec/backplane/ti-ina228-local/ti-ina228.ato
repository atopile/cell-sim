#pragma experiment("TRAITS")
#pragma experiment("BRIDGE_CONNECT")
#pragma experiment("MODULE_TEMPLATING")
import ElectricPower
import ElectricLogic
import I2C
import Resistor
import Capacitor
import DifferentialPair
import can_bridge_by_name
# FIXME: TIAddressor2 uses deprecated faebryk.core.moduleinterface API
# from "ti_addressor2.py" import TIAddressor2

from "parts/Texas_Instruments_INA228AQDGSRQ1/Texas_Instruments_INA228AQDGSRQ1.ato" import Texas_Instruments_INA228AQDGSRQ1_package

module TI_INA228:
    """
    Texas Instruments INA228 85V, 20-bit, Ultra-Precise I2C Current/Power Monitor

    High-precision current and power monitoring IC with 20-bit delta-sigma ADC.
    Supports high-side and low-side current sensing with up to 85V common-mode voltage.
    Features integrated temperature sensor and configurable alert functionality.

    Key Specifications:
    • ADC Resolution: 20-bit delta-sigma (312.5nV LSB @ 163.84mV full-scale)
    • Common-Mode Voltage: -0.3V to +85V (VBUS pin)
    • Shunt Voltage Range: ±163.84mV (programmable to ±40.96mV)
    • Supply Voltage: 2.7V to 5.5V
    • Supply Current: ~1.4mA typical
    • Input Bias Current: 2.5nA maximum (excellent for precision)
    • Offset Voltage: ±1µV maximum
    • Gain Error: ±0.05% maximum
    • Temperature Sensor: ±1°C accuracy
    • I2C Speed: Up to 2.94 MHz
    • Alert Response Time: 75µs typical

    External connections provided by this driver:
    • power        – Device supply (2.7V to 5.5V)
    • power_in     – High-side sense input (before shunt, up to 85V)
    • power_out    – High-side sense output (after shunt)
    • i2c          – I²C bus (16 selectable addresses: 0x40-0x4F)
    • alert        – Open-drain ALERT pin (over-limit interrupt)
    • a0_config    – Address pin A0 (connect to GND, VS, SDA, or SCL)
    • a1_config    – Address pin A1 (connect to GND, VS, SDA, or SCL)

    SAFETY WARNING: VBUS pin can handle up to 85V. Ensure proper PCB isolation
    and follow high-voltage design practices when using voltages above 30V.
    """

    # --- Package ---
    package = new Texas_Instruments_INA228AQDGSRQ1_package

    # --- Supply ---
    power = new ElectricPower
    """
    Device power supply (2.7V to 5.5V)
    """
    power.required = True
    assert power.voltage within 2.7V to 5.5V
    power.hv ~ package.VS
    power.lv ~ package.GND

    # --- I²C bus ---
    i2c = new I2C
    """
    I²C bus interface (16 selectable addresses: 0x40-0x4F)
    Supports up to 2.94 MHz high-speed mode
    """
    i2c.required = True
    i2c.scl.line ~ package.SCL
    i2c.sda.line ~ package.SDA
    i2c.scl.reference ~ power
    i2c.sda.reference ~ power

    # --- I2C pullup resistors ---
    pullup_scl = new Resistor
    pullup_sda = new Resistor
    pullup_scl.resistance = 10kohm +/- 5%
    pullup_sda.resistance = 10kohm +/- 5%
    pullup_scl.package = "0402"
    pullup_sda.package = "0402"
    i2c.scl.line ~> pullup_scl ~> i2c.scl.reference.vcc
    i2c.sda.line ~> pullup_sda ~> i2c.sda.reference.vcc

    # --- ALERT output ---
    alert = new ElectricLogic
    """
    Programmable alert output (open-drain, active low)
    Triggers on user-defined over/under limit conditions
    """
    alert.line ~ package.ALERT
    alert.reference ~ power

    # Alert pullup resistor (required for open-drain output)
    alert_pullup = new Resistor
    alert_pullup.resistance = 10kohm +/- 5%
    alert_pullup.package = "0402"
    alert.line ~> alert_pullup ~> alert.reference.vcc

    # --- Shunt measurement path ---
    # PCB Layout Guidelines:
    # 1. Keep shunt resistor as close as possible to INpos/INneg pins
    # 2. Use Kelvin connections - separate traces for current path and voltage sensing
    # 3. Route INpos/INneg traces away from switching circuits to minimize noise
    # 4. Use solid ground plane underneath the INA228 and shunt resistor
    # 5. Keep decoupling capacitor within 5mm of VS pin
    shunt_input = new DifferentialPair
    """
    Differential shunt voltage input (±163.84mV full scale)
    Connect directly to shunt resistor with Kelvin connections
    """
    shunt_input.p.line ~ package.INpos
    shunt_input.n.line ~ package.INneg

    # User-defined maximum current parameter
    max_current: current
    """
    Maximum expected current for automatic shunt resistor sizing
    """
    # Default to 1 A to provide initial constraint (can be overridden by instantiations)
    max_current = 1A

    # INA228 default full-scale shunt drop (programmable). Use 163.84 mV typical.
    shunt_drop = 163.84mV

    # External shunt resistor (designer selects value & package)
    shunt = new Resistor
    shunt.package = "R1206"  # adequate power rating for most designs
    shunt_input.p.line ~> shunt ~> shunt_input.n.line

    # Recommended shunt value bounds given desired max current
    assert shunt.resistance <= shunt_drop / max_current * 1.1
    assert shunt.resistance >= shunt_drop / max_current * 0.9

    # --- High-side bridge so designers can insert the monitor inline ---
    power_in = new ElectricPower
    """
    High-side power input (before shunt, -0.3V to 85V)
    Connect to power source being monitored
    """
    power_in.required = True

    power_out = new ElectricPower
    """
    High-side power output (after shunt)
    Connect to load being powered
    """
    power_out.required = True

    # Common ground ties to device ground
    power_in.lv ~ power.lv
    power_out.lv ~ power.lv

    # Bridge VCC path through shunt
    power_in.hv ~> shunt ~> power_out.hv

    # Connect VBUS to monitor input voltage
    package.VBUS ~ power_in.hv

    # VBUS voltage constraint (common-mode voltage range)
    # The INA228 can handle up to 85V on VBUS pin
    # Note: This is a high voltage - ensure proper PCB isolation
    assert power_in.voltage within -0.3V to 85V

    # Mark module as a bridge so it can be inserted inline in power path
    trait can_bridge_by_name<input_name="power_in", output_name="power_out">

    # --- Decoupling capacitor on VS ---
    decouple = new Capacitor
    decouple.capacitance = 100nF +/- 10%
    decouple.package = "C0402"
    power.hv ~> decouple ~> power.lv

    # --- I²C address selection (A1, A0) ---
    # INA228 has 16 selectable addresses via A0 and A1 pins
    # Each pin can be connected to: GND=0, VS=1, SDA=2, SCL=3
    # Address = 0x40 + (A1_config << 2) + (A0_config << 1)
    # This gives addresses from 0x40 to 0x4F (16 total)

    # --- I2C address selection (A1, A0) ---
    # FIXME: TIAddressor2 Python module uses deprecated faebryk API.
    # Hardwire A0=GND, A1=GND for address 0x40 (default).
    # Reconnect A0/A1 to VS/SDA/SCL for other addresses as needed.
    package.A0 ~ power.lv
    package.A1 ~ power.lv
    assert i2c.address within 0x40 to 0x4F
