#pragma experiment("FOR_LOOP")
#pragma experiment("BRIDGE_CONNECT")

import Resistor
import Capacitor
import Diode
import Inductor
import ElectricPower
import ElectricLogic
import ElectricSignal

from "parts/Texas_Instruments_TPS54560DDAR/Texas_Instruments_TPS54560DDAR.ato" import Texas_Instruments_TPS54560DDAR_package
from "parts/STMicroelectronics_STPS340U/STMicroelectronics_STPS340U.ato" import STMicroelectronics_STPS340U
from "parts/Sunlord_SWPA8040S5R6NT/Sunlord_SWPA8040S5R6NT.ato" import Sunlord_SWPA8040S5R6NT
from "regulators.ato" import AdjustableRegulator

module TI_TPS54560 from AdjustableRegulator:
    """
    Texas Instruments TPS54560x Buck Converter
    Input: 4.5V to 60V
    Output: 0.8V to 58.8V (adjustable)
    Output Current: up to 5A
    Switching Frequency: up to 2.2MHz
    """
    # External interfaces
    enable = new ElectricLogic

    # Components
    package = new Texas_Instruments_TPS54560DDAR_package
    diode = new STMicroelectronics_STPS340U
    input_caps = new Capacitor[3]
    output_caps = new Capacitor[4]
    inductor = new Sunlord_SWPA8040S5R6NT
    bootstrap_capacitor = new Capacitor
    compensation_resistor = new Resistor
    compensation_capacitors = new Capacitor[2]
    switching_frequency_resistor = new Resistor

    # Constraints
    assert power_in.voltage is input_voltage
    assert power_out.voltage is output_voltage
    assert input_voltage within 4.5V to 60V
    assert output_voltage within 0.8V to 58.8V
    assert input_voltage >= output_voltage  # Buck converter constraint

    # Set feedback reference voltage
    assert reference_voltage is 0.8V +/- 0.1%

    # Input caps
    for cap in input_caps:
        cap.max_voltage = 30V to 100V
        cap.package = "0805"
        cap.capacitance = 10uF +/- 20%

    # Output caps
    for cap in output_caps:
        cap.max_voltage = 16V to 100V
        cap.package = "0805"
        cap.capacitance = 22uF +/- 20%

    # Bootstrap cap
    bootstrap_capacitor.max_voltage = 30V to 100V
    bootstrap_capacitor.package = "0402"
    bootstrap_capacitor.capacitance = 100nF +/- 20%

    # Compensation components
    for cap in compensation_capacitors:
        cap.max_voltage = 30V to 100V
        cap.package = "0402"

    compensation_capacitors[0].capacitance = 4.3nF +/- 20%
    compensation_capacitors[1].capacitance = 8.2pF +/- 30%
    compensation_resistor.max_voltage = 30V to 100V
    compensation_resistor.package = "0402"
    compensation_resistor.resistance = 23.7kohm +/- 2%

    # Switching frequency resistor
    switching_frequency_resistor.max_voltage = 30V to 100V
    switching_frequency_resistor.package = "0402"
    switching_frequency_resistor.resistance = 162kohm +/- 2% # 600kHz

    # Power
    power_in.vcc ~ package.VIN
    power_in.gnd ~ package.GND
    power_out.gnd ~ package.GND
    power_out.gnd ~ package.EP

    # Input Filtering
    for cap in input_caps:
        power_in ~ cap.power

    # Output Stage
    package.SW ~> inductor ~> power_out.vcc
    package.SW <~ diode <~ power_out.gnd
    for cap in output_caps:
        power_out ~ cap.power

    # Compensation
    package.COMP ~> compensation_resistor ~> compensation_capacitors[0] ~> power_in.gnd
    package.COMP ~> compensation_capacitors[1] ~> power_in.gnd
    package.BOOT ~> bootstrap_capacitor ~> package.SW
    package.RT_CLK ~> switching_frequency_resistor ~> power_in.gnd

    # Feedback
    # Base class (AdjustableRegulator) already connects: power_out ~ feedback_divider.ref_in
    package.FB ~ feedback_divider.ref_out.hv
    feedback_divider.chain.resistors[0].package = "R0402"
    feedback_divider.chain.resistors[1].package = "R0402"

    # Enable
    enable.line ~ package.EN
    enable.reference.gnd ~ power_in.gnd
