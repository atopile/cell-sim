#pragma experiment("BRIDGE_CONNECT")
#pragma experiment("TRAITS")

import ElectricPower
import Regulator
import Capacitor

from "parts/YLPTEC_B2405S_2WR3/YLPTEC_B2405S_2WR3.ato" import YLPTEC_B2405S_2WR3_package
from "parts/YLPTEC_B0505S_2WR3/YLPTEC_B0505S_2WR3.ato" import YLPTEC_B0505S_2WR3_package
from "parts/YLPTEC_B1205S_2WR2/YLPTEC_B1205S_2WR2.ato" import YLPTEC_B1205S_2WR2_package
from "parts/YLPTEC_B2412S_3WR2/YLPTEC_B2412S_3WR2.ato" import YLPTEC_B2412S_3WR2_package
from "parts/YLPTEC_B2403S_3WR2/YLPTEC_B2403S_3WR2.ato" import YLPTEC_B2403S_3WR2_package

module YLPTEC_B2405S_2WR3 from Regulator:
    """
    YLPTEC B2405S-2WR3 Isolated 2W DC-DC Converter
    - Input: 24V (21.6V to 26.4V)
    - Output: 5V (400mA max)
    - Galvanically isolated input/output
    - SIP-6 package
    """

    # --- External interfaces ---
    power_in.required = True
    """Input power supply (24V nominal, ±10%)"""

    power_out.required = True
    """Isolated 5V output rail"""

    # --- Voltage constraints ---
    assert power_in.voltage within 21.6V to 26.4V
    assert power_out.voltage within 4.75V to 5.25V

    # --- Package ---
    package = new YLPTEC_B2405S_2WR3_package

    # --- Package connections ---
    # Input side
    package.Vin ~ power_in.hv
    package.GND ~ power_in.lv

    # Output side (isolated)
    package.VOpos ~ power_out.hv
    package.P0V ~ power_out.lv

    # --- Input decoupling capacitor ---
    input_cap = new Capacitor
    input_cap.capacitance = 2.2uF +/- 20%
    input_cap.package = "0805"
    power_in.hv ~> input_cap ~> power_in.lv

    # --- Output decoupling capacitor ---
    output_cap = new Capacitor
    output_cap.capacitance = 10uF +/- 20%
    output_cap.package = "0805"
    power_out.hv ~> output_cap ~> power_out.lv

