#pragma experiment("FOR_LOOP")
#pragma experiment("BRIDGE_CONNECT")

import Resistor
import Capacitor
import Inductor
import ElectricPower
import ElectricLogic
import ElectricSignal
from "regulators.ato" import AdjustableRegulator # std lib import

from "parts/Texas_Instruments_TPS563201DDCR/Texas_Instruments_TPS563201DDCR.ato" import Texas_Instruments_TPS563201DDCR_package


module TI_TPS563201 from AdjustableRegulator:
    """
    Texas Instruments TPS563201DDCR Buck Regulator
    Vin: 4.5V - 17V
    Vout: 0.76V - 7V
    Iout: up to 3A
    """

    # External Interfaces (power_in and power_out defined in parent)
    enable = new ElectricLogic

    # Components
    package = new Texas_Instruments_TPS563201DDCR_package

    # Set parameters
    assert power_in.voltage within 4.5V to 17V
    assert power_out.voltage within 0.76V to 7V

    # Set feedback reference voltage
    assert reference_voltage is 0.768V +/- 0.1%

    # Configure feedback divider
    feedback_divider.chain.resistors[0].package = "R0402"
    feedback_divider.chain.resistors[1].package = "R0402"
    feedback_divider.chain.resistors[0].resistance = 10kohm +/- 1%
    # HACK: commented out to work around solver loop bug
    # TODO: restore once atopile solver is fixed
    # assert feedback_divider.current within 10uA to 1mA
    # assert input_voltage >= output_voltage

    # Power Connections
    power_in.vcc ~ package.VIN
    power_in.gnd ~ package.GND
    power_out.gnd ~ package.GND

    # Feedback
    # Base class (AdjustableRegulator) already connects: power_out ~ feedback_divider.ref_in
    package.VFB ~ feedback_divider.ref_out.hv

    # Input caps
    input_caps = new Capacitor[3]
    for cap in input_caps[:2]:
        cap.capacitance = 10uF +/- 20%
        cap.package = "0805"

    input_caps[2].capacitance = 100nF +/- 20%
    input_caps[2].package = "0402"

    # Connect Input Caps
    for cap in input_caps:
        power_in.vcc ~> cap ~> power_in.gnd


    # Output caps
    output_caps = new Capacitor[3]
    for cap in output_caps:
        cap.capacitance = 10uF +/- 20%
        cap.package = "0805"
        power_out.vcc ~> cap ~> power_out.gnd


    # Bootstrap cap
    bootstrap_cap = new Capacitor
    bootstrap_cap.capacitance = 100nF +/- 20%
    bootstrap_cap.package = "0402"
    bootstrap_cap.max_voltage = 10V to 30V
    package.VBST ~> bootstrap_cap ~> package.SW

    # Inductor
    inductor = new Inductor
    inductor.inductance = 2.2uH +/- 30%
    assert inductor.max_current >= 3A
    inductor.package = "SMD5x5mm"
    package.SW ~> inductor ~> power_out.vcc

    # Enable
    enable.line ~ package.EN
    enable.reference.gnd ~ power_in.gnd

    # Default Enabled (pull-up)
    enable_resistor = new Resistor
    enable_resistor.resistance = 10kohm +/- 5%
    enable_resistor.package = "0402"
    package.EN ~> enable_resistor ~> power_in.vcc
