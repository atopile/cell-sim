#pragma experiment("BRIDGE_CONNECT")

# Minimal test: regulators with explicit feedback divider values
# to verify solver convergence

import ElectricPower

from "ti-tps563201-local/ti-tps563201.ato" import TI_TPS563201
from "atopile/ti-tlv75901/ti-tlv75901.ato" import TI_TLV75901
from "st-ldk220-local/st-ldk220.ato" import LDK220M_R


module SolverTest:
    "Test explicit feedback divider values for solver convergence"

    power_in = new ElectricPower
    power_buck = new ElectricPower
    power_ldo = new ElectricPower
    power_3v3 = new ElectricPower

    # === Buck (TPS563201): 8V -> 5V ===
    buck = new TI_TPS563201
    power_in ~> buck ~> power_buck
    assert power_buck.voltage within 5V +/- 2%
    # R_top already 10kohm in package; set R_bot explicitly
    # Vout = 0.768 * (1 + 10k/1.8k) = 5.03V
    buck.feedback_divider.chain.resistors[1].resistance = 1.8kohm +/- 1%

    # === LDO (TLV75901): 5V -> 4V ===
    ldo = new TI_TLV75901
    power_buck ~> ldo ~> power_ldo
    assert power_ldo.voltage within 4V +/- 2%
    # Vout = 0.55 * (1 + 47k/7.5k) = 3.997V
    ldo.feedback_divider.chain.resistors[0].resistance = 47kohm +/- 1%
    ldo.feedback_divider.chain.resistors[1].resistance = 7.5kohm +/- 1%

    # === Control LDO (LDK220M_R): 8V -> 3.3V ===
    ctrl_ldo = new LDK220M_R
    power_in ~> ctrl_ldo ~> power_3v3
    assert power_3v3.voltage within 3.3V +/- 2%
    # Vout = 1.185 * (1 + 100k/56k) = 3.30V
    ctrl_ldo.feedback_divider.chain.resistors[0].resistance = 100kohm +/- 1%
    ctrl_ldo.feedback_divider.chain.resistors[1].resistance = 56kohm +/- 1%
