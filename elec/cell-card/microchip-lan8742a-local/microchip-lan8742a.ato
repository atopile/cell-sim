#pragma experiment("FOR_LOOP")
#pragma experiment("BRIDGE_CONNECT")

import ElectricPower
import ElectricLogic
import ElectricSignal
import Ethernet
import RMII
import MDIO
import Capacitor
import Resistor
from "parts/Microchip_Tech_LAN8742A_CZ_TR/Microchip_Tech_LAN8742A_CZ_TR.ato" import Microchip_Tech_LAN8742A_CZ_TR_package
from "parts/Yangxing_Tech_X322525MRB4SI/Yangxing_Tech_X322525MRB4SI.ato" import Yangxing_Tech_X322525MRB4SI_package


module Microchip_LAN8742A:
    """
    Microchip LAN8742A 10/100 Ethernet PHY (RMII). HP Auto-MDIX, flexPWR.
    May use single 3.3V supply; has integrated 1.2V regulator.
    Datasheet: LAN8742A/LAN8742Ai.
    """

    # --- External interfaces ---
    power_3v3 = new ElectricPower
    """
    3.3 V main supply for PHY (may be used as single-supply mode)
    """
    power_3v3.required = True
    assert power_3v3.voltage within 3.0V to 3.6V

    rmii = new RMII
    """
    RMII data interface to the MAC
    """

    mdio = new MDIO
    """
    MDIO/MDC management interface (SMI)
    """
    mdio.required = True

    leds = new ElectricLogic[2]
    """
    Two LED outputs
    """

    # --- Internal rails ---
    _power_1v2 = new ElectricPower
    """
    Internal 1.2V rail (from integrated regulator)
    """

    # --- Additional interfaces ---
    ethernet = new Ethernet
    """
    Twisted-pair Ethernet MDI (to magnetics/RJ45)
    """

    _reset = new ElectricLogic
    """
    Internal reset net (active low), pulled up to 3v3
    """

    # --- Package ---
    package = new Microchip_Tech_LAN8742A_CZ_TR_package

    # --- Power connections ---
    package.VDDIO ~ power_3v3.hv
    package.VDD1A ~ power_3v3.hv
    package.VDD2A ~ power_3v3.hv
    package.VSS ~ power_3v3.lv

    # 1.2 V internal regulator output and decoupling (1µF || 470pF to GND)
    _power_1v2.hv ~ package.VDDCR
    vddcr_caps = new Capacitor[2]
    vddcr_caps[0].capacitance = 1uF +/- 20%
    vddcr_caps[0].package = "0402"
    vddcr_caps[1].capacitance = 470pF +/- 20%
    vddcr_caps[1].package = "0402"
    for cap in vddcr_caps:
        _power_1v2.hv ~> cap ~> power_3v3.lv

    # 3.3 V decoupling
    decoupling_3v3 = new Capacitor[4]
    for cap in decoupling_3v3:
        cap.capacitance = 100nF +/- 20%
        cap.package = "0402"
        power_3v3.hv ~> cap ~> power_3v3.lv

    # 3.3 V bulk decoupling (local reservoir)
    decoupling_3v3_bulk = new Capacitor
    decoupling_3v3_bulk.capacitance = 1uF +/- 20%
    decoupling_3v3_bulk.package = "0402"
    power_3v3.hv ~> decoupling_3v3_bulk ~> power_3v3.lv

    # RBIAS resistor (per datasheet 12.1kΩ ±1% to GND)
    rbias_12k1 = new Resistor
    rbias_12k1.resistance = 12.1kohm +/- 1%
    rbias_12k1.package = "0402"
    package.RBIAS ~> rbias_12k1 ~> power_3v3.lv

    # Straps (weak) to set safe defaults without impacting runtime I/O
    # Ensure internal regulator enabled by default (REGOFF low via weak pulldown)
    regoff_pd = new Resistor
    regoff_pd.resistance = 100kohm +/- 5%
    regoff_pd.package = "0402"
    package.LED1_nINT_nPME_REGOFF ~> regoff_pd ~> power_3v3.lv

    # Set default PHY address = 0 via weak pulldown on PHYAD0 strap
    phyad0_pd = new Resistor
    phyad0_pd.resistance = 100kohm +/- 5%
    phyad0_pd.package = "0402"
    package.RXER_PHYAD0 ~> phyad0_pd ~> power_3v3.lv

    # MDIO/MDC management interface
    mdio.mdc.line ~ package.MDC
    mdio.mdio.line ~ package.MDIO
    mdio.mdc.reference ~ power_3v3
    mdio.mdio.reference ~ power_3v3

    # 25 MHz crystal
    crystal = new Yangxing_Tech_X322525MRB4SI_package
    crystal.OSC1 ~ package.XTAL1_CLKIN
    crystal.OSC2 ~ package.XTAL2
    crystal.GND ~ power_3v3.lv

    # Crystal load capacitors (18 pF each typical)
    xtal_caps = new Capacitor[2]
    for cap in xtal_caps:
        cap.capacitance = 18pF +/- 10%
        cap.package = "0402"
    crystal.OSC1 ~> xtal_caps[0] ~> power_3v3.lv
    crystal.OSC2 ~> xtal_caps[1] ~> power_3v3.lv

    # RMII interface mapping
    rmii.ref_clk.line ~ package.nINT_REFCLKO
    rmii.ref_clk.reference ~ power_3v3

    rmii.txd[0].line ~ package.TXD0
    rmii.txd[1].line ~ package.TXD1
    rmii.tx_en.line ~ package.TXEN

    rmii.rxd[0].line ~ package.RXD0_MODE0
    rmii.rxd[1].line ~ package.RXD1_MODE1
    rmii.crs_dv.line ~ package.CRS_DV_MODE2
    rmii.rx_er.line ~ package.RXER_PHYAD0

    rmii.txd[0].reference ~ power_3v3
    rmii.txd[1].reference ~ power_3v3
    rmii.tx_en.reference ~ power_3v3
    rmii.rxd[0].reference ~ power_3v3
    rmii.rxd[1].reference ~ power_3v3
    rmii.crs_dv.reference ~ power_3v3
    rmii.rx_er.reference ~ power_3v3

    # Ethernet MDI pairs to magnetics/RJ45
    ethernet.pairs[0].p.line ~ package.RXP
    ethernet.pairs[0].n.line ~ package.RXN
    ethernet.pairs[1].p.line ~ package.TXP
    ethernet.pairs[1].n.line ~ package.TXN
    ethernet.pairs[0].p.reference ~ power_3v3
    ethernet.pairs[0].n.reference ~ power_3v3
    ethernet.pairs[1].p.reference ~ power_3v3
    ethernet.pairs[1].n.reference ~ power_3v3

    # Reset (active low) with pull-up (internal)
    _reset.reference ~ power_3v3
    _reset.line ~ package.nRST
    reset_pullup = new Resistor
    reset_pullup.resistance = 10kohm +/- 5%
    reset_pullup.package = "0402"
    _reset.line ~> reset_pullup ~> power_3v3.hv

    # LED outputs
    leds[0].line ~ package.LED1_nINT_nPME_REGOFF
    leds[1].line ~ package.LED2_nINT_nPME_nINTSEL
    leds[0].reference ~ power_3v3
    leds[1].reference ~ power_3v3

    # Map to Ethernet interface LEDs
    ethernet.led_link ~ leds[0]
    ethernet.led_speed ~ leds[1]
    ethernet.led_link.reference ~ power_3v3
    ethernet.led_speed.reference ~ power_3v3
